{:paths ["src"]
 ;; log (renamed from commit-dag, ADR-2607050800 -- Datomic's own term for
 ;; this immutable, append-only transaction sequence), Wave 1/2 of
 ;; ADR-2607022600. Same one Wave-0 dep as prolly-tree, but independent of it
 ;; -- a commit wraps an opaque `state` value (typically a prolly-tree root
 ;; CID, or arrangement's 4-index roots as a map of {index-name cid}), so this
 ;; namespace has no compile-time dependency on prolly-tree or arrangement.
 :deps {io.github.kotoba-lang/ipld {:git/sha "fe67f8e4233792e606da75fceace89a1e6e2ae01"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
